# ===== Base de datos =====
# SQLite por defecto (para empezar). Para PostgreSQL usar:
# DATABASE_URL=postgresql+psycopg://usuario:pass@localhost:5432/transferencias
DATABASE_URL=sqlite:///./data/app.db

# ===== Seguridad =====
# Clave para encriptar credenciales de Evolution API en la BD (Fernet, 32 bytes base64).
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_FERNET
# Secreto para firmar los JWT del login del dashboard
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO
# Usuario/contraseña del dashboard (la contraseña se hashea al iniciar)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esta_clave

# ===== Zona horaria (corte diario) =====
TIMEZONE=America/Guayaquil

# ===== Email (SMTP) para el informe diario =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_FROM=tu_correo@gmail.com
SMTP_USE_TLS=true

# ===== URL pública del backend (para registrar el webhook en Evolution API) =====
# Debe ser accesible desde el servidor de Evolution API.
PUBLIC_BASE_URL=http://localhost:8000

# ===== OCR / LLM =====
TESSERACT_CMD=tesseract
TESSERACT_LANG=spa+eng
# Modo de parsing: "rules" (solo OCR+regex) o "hybrid" (OCR + modelo local Ollama)
PARSE_MODE=rules
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Carpeta donde se guardan las imágenes originales
MEDIA_DIR=./data/media
